model Post {
  id        String   @id @default(uuid())
  header    String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  comments Comment[]

  tags Tag[] @relation("PostTags")

  @@map("posts")
}
